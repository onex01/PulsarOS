# PulsarOS Init Configuration
# SPDX-License-Identifier: MIT

on post-fs-data
    mkdir /data/pulsaros 0750 system system
    mkdir /data/pulsaros/ssh 0700 system system

on property:sys.boot_completed=1
    chmod 0755 /vendor/bin/storage-watcher.sh
    chmod 0755 /vendor/bin/ssh-toggle.sh
    chmod 0755 /vendor/bin/set-resolution.sh
    start storage-watcher
    # Auto-start SSH only if debug build
    exec u:r:su:s0 -- /system/bin/sh -c "[ \"$(getprop ro.build.type)\" = \"userdebug\" ] && /vendor/bin/ssh-toggle.sh start"

service storage-watcher /vendor/bin/sh /vendor/bin/storage-watcher.sh
    class late_start
    user root
    group root sdcard_rw
    disabled

service ssh-manager /vendor/bin/sh /vendor/bin/ssh-toggle.sh start
    class late_start
    user root
    group root
    disabled
    oneshot

# ZRAM для маломощных версий
on property:sys.boot_completed=1
    write /sys/block/zram0/comp_algorithm lz4
    write /sys/block/zram0/disk_size 1073741824
    exec u:r:system_server:s0 -- /system/bin/sh -c "mkswap /dev/block/zram0 && swapon /dev/block/zram0"