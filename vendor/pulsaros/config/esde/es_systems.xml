<?xml version="1.0" encoding="utf-8"?>
<!--
     PulsarOS EmulationStation-DE Systems Config
     SPDX-License-Identifier: MIT
     Paths: Android external storage → /storage/UUID/PulsarOS/roms/
-->
<systemList>
  <!-- Nintendo -->
  <system>
    <name>nes</name>
    <fullname>Nintendo Entertainment System</fullname>
    <path>/storage/PulsarOS/roms/nes</path>
    <extension>.nes .fds .zip .NES .FDS .ZIP</extension>
    <command>am start -n com.retroarch/.browser.retroactivity.RetroActivityFuture -e ROM %ROM% -e LIBRETRO /vendor/lib/libretro/nestopia_libretro.so -e CONFIGFILE /vendor/etc/retroarch/retroarch.cfg</command>
    <platform>nes</platform>
    <theme>nes</theme>
  </system>
