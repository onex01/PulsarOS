<?xml version="1.0" encoding="UTF-8"?>
<!-- ==========================================================================
     PulsarOS — ES-DE systems config
     Пути настроены под PulsarOS storage layout:
     /storage/<UUID>/PulsarOS/roms/<система>/
     =========================================================================
-->
<systemList>

    <!-- NES -->
    <system>
        <name>nes</name>
        <fullname>Nintendo Entertainment System</fullname>
        <path>%ROMPATH%/nes</path>
        <extension>.nes .NES .zip .ZIP .7z .7Z</extension>
        <command label="RetroArch (fceumm)">
            am start --user 0 -n com.retroarch/.browser.retroactivity.RetroActivityFuture
            -e ROM %ROM% -e LIBRETRO /data/data/com.retroarch/cores/fceumm_libretro_android.so
        </command>
        <platform>nes</platform>
        <theme>nes</theme>
    </system>

    <!-- SNES -->
    <system>
        <name>snes</name>
        <fullname>Super Nintendo Entertainment System</fullname>
        <path>%ROMPATH%/snes</path>
        <extension>.sfc .SFC .smc .SMC .zip .ZIP .7z .7Z</extension>
